algoritmo "semnome"
// Funçăo :
// Autor :
// Data : 08/03/2021
// Seçăo de Declaraçőes 
var
   n1, n2, s: inteiro

inicio
// Seçăo de Comandos 
   Escreva("Informe um número: ")
   Leia(n1)
   Escreva("Informe outro número: ")
   Leia(n2)
   
   s <- n1+n2
   
   Escreva("A soma entre ", n1, " e ", n2, " é ", s)
   
fimalgoritmo
